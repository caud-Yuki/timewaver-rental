
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profiles: Owners can read and write their own profiles.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Devices: Public read access for the catalog. Admins can write.
    match /devices/{deviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // News: Public read access for published news. Admins can write.
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Applications: Users can read and write only their own applications. Admins can do everything.
    match /applications/{applicationId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // Support Requests: Users can read/create their own. Admins can manage all.
    match /supportRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    // Coupons: Admin read/write. Users read-only if active.
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Email Templates: Admin only.
    match /emailTemplates/{templateId} {
      allow read, write: if isAdmin();
    }

    // Waitlist: Users can create/read their own. Admins can manage all.
    match /waitlist/{waitlistId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    // Payment Links: User/Admin access.
    match /paymentLinks/{linkId} {
      allow read: if true; // Public access to allow payment page to check link
      allow write: if isAdmin();
    }

    // Global Settings: Admin only access.
    match /settings/global {
      allow read, write: if isAdmin();
    }
  }
}
