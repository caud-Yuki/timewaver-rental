rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Devices: Public read access for the catalog. Admins can write.
    match /devices/{deviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Applications: Users can read and write only their own applications. Admins can do everything.
    match /applications/{applicationId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // For list operations, the query MUST have a filter that matches these constraints.
      allow read: if request.auth != null && (
        isAdmin() || 
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource == null) // Allow the query itself to be evaluated
      );
      
      allow update, delete: if isAdmin() || (
        request.auth != null && resource.data.userId == request.auth.uid
      );
    }

    // User Profiles: Owners can read and write their own profiles.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}