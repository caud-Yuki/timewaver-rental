
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profiles: Owners can read and write their own profiles. Admins can read all.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Devices: Public read access for the catalog. Admins can write.
    match /devices/{deviceId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth != null && (
          // 1. User locks an available device to start application
          (resource.data.status == 'available' && request.resource.data.status == 'processing' && request.resource.data.currentUserId == request.auth.uid) ||
          // 2. User releases a processing device (timeout or back button)
          (resource.data.status == 'processing' && resource.data.currentUserId == request.auth.uid && request.resource.data.status == 'available') ||
          // 3. User completes payment and activates device
          (resource.data.status == 'processing' && resource.data.currentUserId == request.auth.uid && request.resource.data.status == 'active')
        )
      );
    }

    // Device Type Codes: Public read access. Admins can manage.
    match /deviceTypeCodes/{codeId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // News: Public read access for published news. Admins can write.
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Applications: Users can read and write only their own applications. Admins can do everything.
    match /applications/{applicationId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // Subscriptions: Users can read their own and create their own (決済完了時). Admins manage all.
    match /subscriptions/{subId} {
      allow read: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Support Requests: Users can read/create their own. Admins can manage all.
    match /supportRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    // Coupons: Admin read/write. Users read-only if active.
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Email Templates: Admin only.
    match /emailTemplates/{templateId} {
      allow read, write: if isAdmin();
    }

    // Email Triggers: Admin only.
    match /emailTriggers/{triggerId} {
      allow read, write: if isAdmin();
    }

    // Device Modules: Public read for product details. Admins manage.
    match /deviceModules/{moduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Modules: Public read for product details. Admins manage.
    match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Waitlist: Users can create their own.
    match /waitlist/{waitlistId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Payment Links: Public read. 決済完了時に認証ユーザーがstatusを'used'へ変更可能. Adminsは全操作可能.
    match /paymentLinks/{linkId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.auth != null && resource.data.status == 'pending' && request.resource.data.status == 'used');
    }

    // Global Settings: Admins can write. Public read (contains non-sensitive config like service name, model settings).
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Consent Form: Public read (terms are public-facing). Admins can write.
    match /consentForm/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials: Public read. Admins manage.
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // FAQs: Public read. Admins manage.
    match /faqs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Case Studies: Public read. Admins manage.
    match /caseStudies/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Early Bookings (先行予約): Anyone can create; only admins can read/update/delete.
    match /earlyBookings/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.name is string;
      allow read, update, delete: if isAdmin();
    }
  }
}
