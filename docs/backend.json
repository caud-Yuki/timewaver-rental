
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "familyName": { "type": "string" },
        "givenName": { "type": "string" },
        "familyNameKana": { "type": "string" },
        "givenNameKana": { "type": "string" },
        "companyName": { "type": "string" },
        "zipcode": { "type": "string" },
        "prefectureCode": { "type": "string" },
        "address1": { "type": "string" },
        "address2": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "tel": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "customerId": { "type": "string" },
        "cardToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "familyName", "givenName", "role", "tel"]
    },
    "Device": {
      "title": "Device",
      "description": "A TimeWaver device available for rental",
      "type": "object",
      "properties": {
        "serialNumber": { "type": "string" },
        "type": { "type": "string", "enum": ["TimeWaver Mobile", "TimeWaver Mobile Quantum", "TimeWaver Tabletop", "TimeWaver Frequency"] },
        "typeCode": { "type": "string", "enum": ["tw-m", "tw-mq", "tw-tt", "tw-frq"] },
        "modules": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["available", "active", "processing", "terminated_early", "terminated"] },
        "description": { "type": "string" },
        "price": {
          "type": "object",
          "properties": {
            "3m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } },
            "6m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } },
            "12m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } }
          }
        },
        "currentUserId": { "type": "string" },
        "contractStartAt": { "type": "string", "format": "date-time" },
        "contractEndAt": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      },
      "required": ["serialNumber", "type", "typeCode", "status", "price"]
    },
    "Application": {
      "title": "Application",
      "description": "A rental application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "deviceId": { "type": "string" },
        "deviceSerialNumber": { "type": "string" },
        "deviceType": { "type": "string" },
        "rentalType": { "type": "number", "enum": [3, 6, 12] },
        "payType": { "type": "string", "enum": ["monthly", "full"] },
        "payAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "payment_sent", "completed", "cancelled"] },
        "identificationImageUrl": { "type": "string" },
        "agreementPdfUrl": { "type": "string" },
        "paymentLinkId": { "type": "string" }
      },
      "required": ["userId", "deviceId", "rentalType", "payType", "payAmount", "status", "identificationImageUrl"]
    },
    "PaymentLink": {
      "title": "PaymentLink",
      "description": "A secure payment link",
      "type": "object",
      "properties": {
        "applicationId": { "type": "string" },
        "userId": { "type": "string" },
        "deviceId": { "type": "string" },
        "serialNumber": { "type": "string" },
        "deviceName": { "type": "string" },
        "payType": { "type": "string", "enum": ["monthly", "full"] },
        "payAmount": { "type": "number" },
        "cycle": { "type": "string", "enum": ["MONTHLY"] },
        "currentlyPayAmount": { "type": "number" },
        "recurringDayOfMonth": { "type": "number", "enum": [1, 15] },
        "maxExecutionNumber": { "type": "number" },
        "payTimes": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "used", "expired"] },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["applicationId", "userId", "payType", "payAmount", "status"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Active rental subscription",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "deviceId": { "type": "string" },
        "payType": { "type": "string", "enum": ["monthly", "full"] },
        "rentalMonths": { "type": "number", "enum": [3, 6, 12] },
        "startAt": { "type": "string", "format": "date-time" },
        "endAt": { "type": "string", "format": "date-time" },
        "recurringId": { "type": "string" },
        "paymentId": { "type": "string" },
        "customerId": { "type": "string" },
        "payAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "payment_failed", "payment_delayed", "completed", "cancelled"] },
        "delayMonths": { "type": "number" },
        "applicationId": { "type": "string" }
      },
      "required": ["userId", "deviceId", "payType", "status", "customerId"]
    },
    "Waitlist": {
      "title": "Waitlist",
      "description": "User on a device waitlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "deviceId": { "type": "string" },
        "deviceType": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "notified", "scheduled", "cancelled", "processing"] },
        "scheduledNotifyAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GlobalSettings": {
      "title": "GlobalSettings",
      "description": "Global platform settings including FirstPay credentials",
      "type": "object",
      "properties": {
        "managerName": { "type": "string" },
        "managerEmail": { "type": "string" },
        "companyName": { "type": "string" },
        "tel": { "type": "string" },
        "zipcode": { "type": "string" },
        "address": { "type": "string" },
        "mode": { "type": "string", "enum": ["test", "production"] },
        "waitlistEmailInterval": { "type": "number", "description": "Hours between automated waitlist notifications" },
        "waitlistValidityHours": { "type": "number", "description": "Hours to wait after last notification before clearing waitlist" },
        "applicationSessionMinutes": { "type": "number", "description": "Minutes before a rental application session expires due to inactivity" },
        "firstpayTest": {
          "type": "object",
          "properties": {
            "apiKey": { "type": "string" },
            "bearerToken": { "type": "string" }
          }
        },
        "firstpayProd": {
          "type": "object",
          "properties": {
            "apiKey": { "type": "string" },
            "bearerToken": { "type": "string" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/devices/{deviceId}": { "schema": "Device", "description": "Device inventory" },
    "/applications/{applicationId}": { "schema": "Application", "description": "Rental applications" },
    "/paymentLinks/{paymentLinkId}": { "schema": "PaymentLink", "description": "Secure payment links" },
    "/subscriptions/{subscriptionId}": { "schema": "Subscription", "description": "Active subscriptions" },
    "/waitlist/{waitlistId}": { "schema": "Waitlist", "description": "Device waitlist entries" },
    "/settings/global": { "schema": "GlobalSettings", "description": "Global settings" }
  }
}
