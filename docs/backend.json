
{
  "entities": {
    "Device": {
      "title": "Device",
      "description": "A TimeWaver device available for rental",
      "type": "object",
      "properties": {
        "serialNumber": { "type": "string" },
        "type": { "type": "string" },
        "typeCode": { "type": "string", "enum": ["tw-m", "tw-mq", "tw-tt", "tw-frq"] },
        "status": { "type": "string", "enum": ["available", "active", "maintenance"] },
        "description": { "type": "string" },
        "price": {
          "type": "object",
          "properties": {
            "3m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } },
            "6m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } },
            "12m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } }
          }
        },
        "imageUrl": { "type": "string" }
      },
      "required": ["serialNumber", "type", "typeCode", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "A rental application submitted by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "deviceId": { "type": "string" },
        "rentalType": { "type": "number", "enum": [3, 6, 12] },
        "payType": { "type": "string", "enum": ["monthly", "full"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "payment_sent", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "deviceId", "rentalType", "payType", "status"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user information",
      "type": "object",
      "properties": {
        "familyName": { "type": "string" },
        "givenName": { "type": "string" },
        "email": { "type": "string" },
        "tel": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["familyName", "givenName", "role"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/devices/{deviceId}": {
      "schema": "Device",
      "description": "Collection of all rental devices. Read access should be public for the catalog."
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Collection of all rental applications. Users can read/write their own applications."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data. Owners can read/write their own profiles."
    }
  }
}
