
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "familyName": { "type": "string" },
        "givenName": { "type": "string" },
        "familyNameKana": { "type": "string" },
        "givenNameKana": { "type": "string" },
        "companyName": { "type": "string" },
        "zipcode": { "type": "string" },
        "prefectureCode": { "type": "string" },
        "address1": { "type": "string" },
        "address2": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "tel": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "customerId": { "type": "string" },
        "cardToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "familyName", "givenName", "role"]
    },
    "Device": {
      "title": "Device",
      "description": "A TimeWaver device available for rental",
      "type": "object",
      "properties": {
        "serialNumber": { "type": "string" },
        "type": { "type": "string" },
        "typeCode": { "type": "string", "enum": ["tw-m", "tw-mq", "tw-tt", "tw-frq"] },
        "modules": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["available", "active", "terminated_early", "terminated"] },
        "description": { "type": "string" },
        "price": {
          "type": "object",
          "properties": {
            "3m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } },
            "6m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } },
            "12m": { "type": "object", "properties": { "full": { "type": "number" }, "monthly": { "type": "number" } } }
          }
        },
        "currentUserId": { "type": "string" },
        "contractStartAt": { "type": "string", "format": "date-time" },
        "contractEndAt": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      }
    },
    "Application": {
      "title": "Application",
      "description": "A rental application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "deviceId": { "type": "string" },
        "deviceSerialNumber": { "type": "string" },
        "deviceType": { "type": "string" },
        "rentalType": { "type": "number" },
        "payType": { "type": "string" },
        "payAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "payment_sent", "completed"] },
        "identificationImageUrl": { "type": "string" },
        "agreementPdfUrl": { "type": "string" },
        "zip": { "type": "string" },
        "tel": { "type": "string" },
        "address": { "type": "string" },
        "paymentLinkId": { "type": "string" }
      }
    },
    "PaymentLink": {
      "title": "PaymentLink",
      "description": "A secure payment link generated for an approved application",
      "type": "object",
      "properties": {
        "applicationId": { "type": "string" },
        "userId": { "type": "string" },
        "deviceId": { "type": "string" },
        "serialNumber": { "type": "string" },
        "deviceName": { "type": "string" },
        "payType": { "type": "string" },
        "payAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "used", "expired"] },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "Waitlist": {
      "title": "Waitlist",
      "description": "A waitlist entry for a device",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "deviceId": { "type": "string" },
        "deviceType": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "notified", "cancelled"] }
      }
    },
    "News": {
      "title": "News",
      "description": "News article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["published", "draft"] },
        "publishedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SupportRequest": {
      "title": "SupportRequest",
      "description": "Repair or support request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "deviceId": { "type": "string" },
        "type": { "type": "string", "enum": ["repair", "support"] },
        "description": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["open", "in_progress", "resolved"] }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "expiresAt": { "type": "string", "format": "date-time" },
        "maxUsesPerUser": { "type": "number" },
        "maxTotalUsers": { "type": "number" },
        "currentUsageCount": { "type": "number" }
      }
    },
    "EmailTemplate": {
      "title": "EmailTemplate",
      "description": "Email template",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["application", "transaction", "news", "waiting", "general"] }
      }
    },
    "GlobalSettings": {
      "title": "GlobalSettings",
      "description": "Platform-wide configuration",
      "type": "object",
      "properties": {
        "managerName": { "type": "string" },
        "managerEmail": { "type": "string" },
        "contactNumber": { "type": "string" },
        "representativeName": { "type": "string" },
        "companyName": { "type": "string" },
        "zipcode": { "type": "string" },
        "address": { "type": "string" },
        "tel": { "type": "string" },
        "mode": { "type": "string", "enum": ["test", "production"] },
        "firstpay": {
          "type": "object",
          "properties": {
            "apiKey": { "type": "string" },
            "bearerToken": { "type": "string" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/devices/{deviceId}": { "schema": "Device", "description": "Device inventory" },
    "/applications/{applicationId}": { "schema": "Application", "description": "Rental applications" },
    "/paymentLinks/{paymentLinkId}": { "schema": "PaymentLink", "description": "Generated payment links" },
    "/waitlist/{waitlistId}": { "schema": "Waitlist", "description": "Device waitlists" },
    "/settings/global": { "schema": "GlobalSettings", "description": "Global config" },
    "/news/{newsId}": { "schema": "News", "description": "News articles" },
    "/supportRequests/{requestId}": { "schema": "SupportRequest", "description": "Support and repair requests" },
    "/coupons/{couponId}": { "schema": "Coupon", "description": "Coupons" },
    "/emailTemplates/{templateId}": { "schema": "EmailTemplate", "description": "Email templates" }
  }
}
